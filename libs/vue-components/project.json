{
  "name": "vue-components",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/vue-components/src",
  "projectType": "library",
  "tags": [],
  "implicitDependencies": ["web-components", "common"],
  "targets": {
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"]
    },
    "build": {
      "executor": "@nx/vite:build",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "outputPath": "dist/libs/vue-components",
        "project": "libs/vue-components/package.json",
        "entryFile": "libs/vue-components/src/index.ts"
      },
      "configurations": {
        "development": {
          "mode": "development"
        },
        "production": {
          "mode": "production"
        }
      }
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": ["{options.reportsDirectory}"],
      "options": {
        "reportsDirectory": "{projectRoot}/../../coverage/libs/vue-components"
      }
    },
    "release": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx semantic-release -e ./libs/vue-components/.releaserc.json"
      }
    }
  }
}
