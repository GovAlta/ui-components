    "value": { "light": "#bab7b7", "dark": "#6a6a6a" },
    "type": "color"
  },
  "radio-label-compact": {
    "value": {
      "fontFamily": "{fontFamily.sans}",
      "fontWeight": "{fontWeight.medium}",
      "fontSize": "{fontSize.3}",
      "lineHeight": "{lineHeight.2}"
    },
    "type": "typography"
  },
  "radio-size": {
    "value": "{space.l}",
    "type": "sizing"
  },
  "radio-reveal-margin": {
    "value": "{space.2xs} 0 0 calc({space.s} - 1px)",
    "type": "spacing"
  },
  "radio-reveal-padding": {
    "value": "{space.m} {space.l}",
    "type": "spacing"
  },
  "radio-reveal-border": {
    "value": {
      "width": "{borderWidth.s}",
      "style": "solid",
      "color": "{color.greyscale.200}"
    },
    "type": "border"
  }
