---
/**
 * ExampleDisplay routes to the appropriate preview shape based on
 * the entry's size. Page-scale entries (page, task, product) use
 * PageScalePreview because their composition usually depends on
 * app shell, mock data, or external sources that don't render
 * usefully inline. Section and interaction snippets use
 * InlinePreview for the sandbox plus framework code tabs.
 */
import type { CollectionEntry } from 'astro:content';
import PageScalePreview from './PageScalePreview.astro';
import InlinePreview from './InlinePreview.astro';
import { isPageScale } from '../lib/example-size';

interface Props {
  example: CollectionEntry<'examples'>;
  /** Title size - 'large' for standalone pages, 'small' for embedded */
  titleSize?: 'large' | 'small';
}

const { example, titleSize = 'small' } = Astro.props;
const pageScale = isPageScale(example.data.size);
---

{pageScale ? (
  <PageScalePreview example={example} />
) : (
  <InlinePreview example={example} titleSize={titleSize} />
)}
