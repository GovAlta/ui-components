---
interface Props {
  title: string;
}

import { withBase } from '@/lib/base-url';

const { title } = Astro.props;
---

<script>
  import("@abgov/web-components");
  import("@abgov/style");
</script>

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="GoA UI Components Documentation" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  body {
    margin: 0;
  }
</style>
