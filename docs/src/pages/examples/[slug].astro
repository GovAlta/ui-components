---
/**
 * Individual Example Page
 *
 * Shows a single example with:
 * - Live preview with framework code tabs
 * - MDX content (when to use, considerations, etc.)
 * - Metadata (category, userType, components used)
 * - Related examples
 */
import { getCollection, render } from 'astro:content';
import ExamplesPageLayout from '../../layouts/ExamplesPageLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import ExampleDisplay from '../../components/ExampleDisplay.astro';
import PreviewContainer from '../../components/PreviewContainer.astro';
import { TableOfContents } from '../../components/TableOfContents';
import { getExampleCode } from '../../lib/example-code';

// Generate static paths for flat examples only. Nested entries
// (workspace/dashboard, etc) are handled by [family]/[page]/index.astro.
export async function getStaticPaths() {
  const examples = await getCollection('examples');
  return examples
    .filter((example) => !example.slug.includes('/'))
    .map((example) => ({
      params: { slug: example.slug },
      props: { example },
    }));
}

const { example } = Astro.props;
const { slug } = Astro.params;
const { data } = example;

// Render the MDX content
const { Content } = await render(example);

// Check if this example has code files
const code = await getExampleCode(example.slug);
const hasCode = !!(code.react || code.angular || code.webComponents);

// Page-and-larger entries render with a PreviewContainer at the top instead
// of framework code tabs, mirroring the workspace page detail shape. The
// framework files still exist on disk and are linked via GitHub.
// Section-sized entries keep the sandbox + framework tabs treatment.
const PAGE_SCALE_SIZES = new Set(['page', 'flow', 'product']);
const isPageScale = PAGE_SCALE_SIZES.has(data.size);
const showCodeTabs = !isPageScale && hasCode;
const useTopPreview = isPageScale && data.previewImage && !data.hideHero;
const githubBlobBase = 'https://github.com/GovAlta/ui-components/blob/dev/docs/src/content/examples';
const githubTreeBase = 'https://github.com/GovAlta/ui-components/tree/dev/docs/src/content/examples';
type WithSourceUrls = { reactSourceUrl?: string; angularSourceUrl?: string; previewUrl?: string };
const pageData = data as typeof data & WithSourceUrls;
const reactSourceUrl =
  pageData.reactSourceUrl ?? (code.react ? `${githubBlobBase}/${slug}/react.tsx` : undefined);
const angularSourceUrl =
  pageData.angularSourceUrl ?? (code.angular ? `${githubTreeBase}/${slug}` : undefined);
// /examples/[slug]/preview.astro auto-generates a Live preview route for
// every flat-slug page-scale entry with a sibling react.tsx. So if this
// entry has React code, link the PreviewContainer image to its preview.
const previewUrl =
  pageData.previewUrl ?? (isPageScale && code.react ? `/examples/${slug}/preview` : undefined);

// Get related examples if defined
let relatedExamples: typeof example[] = [];
if (data.relatedExamples?.length) {
  const allExamples = await getCollection('examples');
  relatedExamples = allExamples.filter(e =>
    data.relatedExamples?.includes(e.data.id)
  );
}

// Format size for display ("page" -> "Page", "component" -> "Component", "digital-service" -> "Digital service")
function formatSize(size: string): string {
  return size
    .split('-')
    .map((word, i) => (i === 0 ? word.charAt(0).toUpperCase() + word.slice(1) : word))
    .join(' ');
}

// Format service type for display ("public-form" -> "Public form")
function formatProductType(productType: string): string {
  return productType
    .split('-')
    .map((word, i) => i === 0 ? word.charAt(0).toUpperCase() + word.slice(1) : word)
    .join(' ');
}

const v1DocsUrl = `https://v1.design.alberta.ca/examples/${slug}`;
---

<ExamplesPageLayout
  title={data.title}
  description={`Example: ${data.title}`}
  currentSlug={slug}
>
  <article class="example-page">
    {/* Only page-scale entries (Dashboard, Start page, etc.) are members of
        a product-type overview's Pages section. Section-scale snippets carry
        a productType for filtering and badges only, so they should not show
        the family crumb. */}
    <Breadcrumbs
      parentGroup={data.productType && data.size === 'page' ? {
        label: formatProductType(data.productType),
        url: `/examples/${data.productType}`,
      } : undefined}
    />
    <!-- Header -->
    <header class="example-header">
      <div class="badges">
        <goa-badge version="2" type="information" emphasis="subtle" icon="false" content={formatSize(data.size)}></goa-badge>
        {data.productType && (
          <goa-badge version="2" type="default" emphasis="subtle" icon="false" content={formatProductType(data.productType)}></goa-badge>
        )}
      </div>
    </header>

    <!-- Header: title, description, and either PreviewContainer (page+) or framework code tabs (component) -->
    {showCodeTabs ? (
      <section class="example-preview-section">
        <ExampleDisplay example={example} titleSize="large" />
      </section>
    ) : useTopPreview ? (
      <section class="example-hero-section">
        <h1 class="example-title">{data.title}</h1>
        {data.description && (
          <p class="example-description" set:html={data.description} />
        )}
        <PreviewContainer
          image={data.previewImage}
          alt={`${data.title} preview`}
          previewUrl={previewUrl}
          reactSourceUrl={reactSourceUrl}
          angularSourceUrl={angularSourceUrl}
        />
      </section>
    ) : (
      <section class="example-hero-section">
        <h1 class="example-title">{data.title}</h1>
        {data.description && (
          <p class="example-description" set:html={data.description} />
        )}
      </section>
    )}

    <!-- MDX Content (When to use, Considerations, etc.) -->
    {!showCodeTabs ? (
      <div class="content-with-toc">
        <section class="example-content">
          <Content />
        </section>
        <aside class="example-toc">
          <div class="example-toc-sticky">
            <TableOfContents client:only="react" cssQuery=".example-content h2[id]" />
          </div>
        </aside>
      </div>
    ) : (
      <section class="example-content">
        <Content />
      </section>
    )}

    {/* end of code-tabs vs TOC switch */}

    <!-- Related Examples -->
    {relatedExamples.length > 0 && (
      <section class="related-examples">
        <h2>Related examples</h2>
        <div class="related-grid">
          {relatedExamples.map((related) => (
            <a href={`/examples/${related.slug}`} class="related-card">
              <span class="related-title">{related.data.title}</span>
              <span class="related-category">{formatSize(related.data.size)}</span>
            </a>
          ))}
        </div>
      </section>
    )}

    <goa-link size="small" trailingicon="open">
      <a href={v1DocsUrl} target="_blank" rel="noopener noreferrer">View old example docs</a>
    </goa-link>
  </article>
</ExamplesPageLayout>

<style>
  .example-page {
    max-width: 1100px;
    margin: 0 auto;
  }

  /* Header */
  .example-header {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    margin-bottom: var(--goa-space-l, 1.5rem);
  }

  /* Badges */
  .badges {
    display: flex;
    gap: var(--goa-space-xs, 0.25rem);
    flex-wrap: wrap;
  }

  .example-title {
    font-size: 2rem;
    font-weight: 700;
    margin: 0;
    color: var(--goa-color-text-default, #333);
    line-height: 1.2;
  }

  .example-description {
    font-size: 1.125rem;
    color: var(--goa-color-text-secondary, #666);
    margin: var(--goa-space-s, 0.5rem) 0 var(--goa-space-l, 1.5rem);
    max-width: 688px;
    line-height: 1.6;
  }

  /* Preview Section */
  .example-preview-section {
    margin-bottom: var(--goa-space-xl, 2rem);
  }

  /* Hero section (when no code preview) */
  .example-hero-section {
    margin-bottom: var(--goa-space-m, 1rem);
  }

  .example-hero-image {
    margin-top: var(--goa-space-l, 1.5rem);
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid var(--goa-color-greyscale-200, #dcdcdc);
  }

  .example-hero-image img {
    width: 100%;
    display: block;
  }

  /* Content Section */
  .example-content {
    margin-bottom: var(--goa-space-2xl, 2.5rem);
  }

  /* Use goa-text typography tokens so MDX headings match the design system's
     heading scale without authors having to wrap each heading in <goa-text>. */
  .example-content :global(h2) {
    font: var(--goa-typography-heading-m);
    margin: var(--goa-space-2xl, 2.5rem) 0 var(--goa-space-m, 1rem);
    color: var(--goa-color-text-default, #333);
  }

  .example-content :global(h2:first-child) {
    margin-top: 0;
  }

  .example-content :global(h3) {
    font: var(--goa-typography-heading-s);
    margin: var(--goa-space-2xl, 2.5rem) 0 var(--goa-space-s, 0.5rem);
    color: var(--goa-color-text-default, #333);
  }

  .example-content :global(p) {
    margin-bottom: var(--goa-space-m, 1rem);
    max-width: 65ch;
    line-height: 1.6;
  }

  .example-content :global(ul),
  .example-content :global(ol) {
    margin: 0 0 var(--goa-space-m, 1rem);
    padding-left: var(--goa-space-l, 1.5rem);
    max-width: 65ch;
  }

  .example-content :global(li) {
    margin-bottom: var(--goa-space-xs, 0.25rem);
  }

  /* Content + TOC grid (for long-form examples without code) */
  .content-with-toc {
    display: grid;
    grid-template-columns: 1fr 180px;
    gap: var(--goa-space-2xl, 2.5rem);
  }

  .example-toc {
    position: relative;
  }

  .example-toc-sticky {
    position: sticky;
    top: var(--goa-space-l, 1.5rem);
    padding-top: var(--goa-space-m, 1rem);
  }

  @media (max-width: 1024px) {
    .content-with-toc {
      grid-template-columns: 1fr;
    }

    .example-toc {
      display: none;
    }
  }

  /* Related Examples */
  .related-examples {
    border-top: 1px solid var(--goa-color-greyscale-200, #dcdcdc);
    padding: var(--goa-space-xl) 0;
  }

  .related-examples h2 {
    font-size: 1.25rem;
    font-weight: 600;
    margin: 0 0 var(--goa-space-m, 1rem);
    color: var(--goa-color-text-default, #333);
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: var(--goa-space-m, 1rem);
  }

  .related-card {
    display: flex;
    flex-direction: column;
    gap: var(--goa-space-2xs, 0.125rem);
    padding: var(--goa-space-m, 1rem);
    background: var(--goa-color-greyscale-100, #f5f5f5);
    border-radius: var(--goa-border-radius-m, 4px);
    text-decoration: none;
    transition: background-color 0.15s ease;
  }

  .related-card:hover {
    background: var(--goa-color-greyscale-200, #e5e5e5);
  }

  .related-title {
    font-weight: 500;
    color: var(--goa-color-interactive-default, #0070c4);
  }

  .related-category {
    font-size: 0.875rem;
    color: var(--goa-color-text-secondary, #666);
  }
</style>
