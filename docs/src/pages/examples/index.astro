---
import { withBase } from '@/lib/base-url';
/**
 * Examples Listing Page
 *
 * Shows all examples with:
 * - Search input
 * - Filter drawer (category, scale, userType)
 * - Table/List/Card view toggle
 * - Grouping options
 * - Two-level sorting
 */
import { getCollection } from 'astro:content';
import ExamplesPageLayout from '../../layouts/ExamplesPageLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { ExamplesGrid } from '../../components/ExamplesGrid';


// Pull both collections so the grid can surface product-type overviews
// alongside their member examples. Synthesizing the productTypes entries
// at render time avoids the stub-MDX duplication we used to have in the
// examples collection.
const allExamples = await getCollection('examples');
const allProductTypes = await getCollection('productTypes');

// Transform examples to the shape ExamplesGrid expects, excluding hidden entries.
const exampleEntries = allExamples
  .filter((example) => !example.data.hidden)
  .map(example => ({
    slug: example.slug,
    data: example.data,
    body: example.data.description || example.body,
  }));

// Synthesize a size:product card per productType. The slug matches the
// /examples/[productType]/ route the [family] page handler already serves.
const productTypeEntries = allProductTypes.map(productType => ({
  slug: productType.slug,
  data: {
    id: productType.data.id,
    title: productType.data.title,
    description: productType.data.summary.replace(/<[^>]+>/g, ''),
    size: 'product' as const,
    components: productType.data.components ?? [],
    tags: productType.data.tags ?? [],
    status: productType.data.status,
    previewImage: productType.data.heroImage,
  },
  body: productType.data.summary,
}));

const examples = [...exampleEntries, ...productTypeEntries].sort((a, b) =>
  a.data.title.localeCompare(b.data.title)
);

---

<ExamplesPageLayout
  title="Examples"
  description="Code examples showing GoA Design System components in context"
>
  <div class="examples-page">
    <Breadcrumbs />
    <!-- Header -->
    <header class="page-header">
      <h1>Examples</h1>
      <p class="page-description">
        Common patterns, pages, tasks, component configurations, flows, and more to use as a starting point when creating government digital services.
      </p>
    </header>

    <!-- Service patterns -->
    <section class="service-patterns">
      <div class="patterns-row">
        <a href={withBase(`/examples/workspace`)} class="pattern-card">
          <img src={withBase(`/images/home/workspace-thumb.png`)} alt="" class="pattern-image" />
          <div class="pattern-text">
            <strong class="pattern-title">Workspace</strong>
            <span class="pattern-desc">For staff who review, manage, and process cases</span>
          </div>
        </a>
        <a href={withBase(`/examples/public-form`)} class="pattern-card">
          <img src={withBase(`/images/home/public-form-thumb.png`)} alt="" class="pattern-image" />
          <div class="pattern-text">
            <strong class="pattern-title">Public form</strong>
            <span class="pattern-desc">For citizens submitting applications and requests</span>
          </div>
        </a>
      </div>
    </section>

    <!-- Examples Grid (React component) -->
    <ExamplesGrid
      client:load
      examples={examples}
    />
  </div>
</ExamplesPageLayout>

<style>
  .examples-page {
    max-width: 1408px;
    margin: 0 auto;
  }

  /* Header */
  .page-header {
    margin-bottom: var(--goa-space-xs, 0.5rem);
  }

  .page-header h1 {
    font: var(--goa-typography-heading-xl);
    margin: 0 0 var(--goa-space-m, 1rem);
    color: var(--goa-color-text-default, #333);
  }

  .page-description {
    font: var(--goa-typography-body-l);
    color: var(--goa-color-text-default, #333);
    margin: 0;
    max-width: 70ch;
  }

  /* Service patterns */
  .service-patterns {
    margin-top: var(--goa-space-xl, 2rem);
    margin-bottom: var(--goa-space-l, 1.5rem);
  }

  .patterns-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: var(--goa-space-m, 1rem);
  }

  .pattern-card {
    display: flex;
    align-items: stretch;
    border: 1px solid var(--goa-color-greyscale-200, #dcdcdc);
    border-radius: var(--goa-border-radius-m, 4px);
    text-decoration: none;
    overflow: hidden;
    transition: border-color 0.15s ease;
  }

  a.pattern-card:hover {
    border-color: var(--goa-color-greyscale-black, #333);
  }

  a.pattern-card:hover .pattern-title {
    text-decoration: underline;
  }

  a.pattern-card:focus-visible {
    outline: 3px solid var(--goa-color-interactive-focus);
    outline-offset: 2px;
  }

  .pattern-card.disabled {
    opacity: 0.7;
  }

  .pattern-image,
  .pattern-image-placeholder {
    width: 100px;
    object-fit: cover;
    flex-shrink: 0;
    background: var(--goa-color-greyscale-100, #f5f5f5);
  }

  .pattern-text {
    display: flex;
    flex-direction: column;
    padding: var(--goa-space-m, 1rem);
    min-width: 0;
  }



  .pattern-title {
    font: var(--goa-typography-body-m);
    font-weight: 600;
    color: var(--goa-color-text-default, #333);
  }

  a.pattern-card .pattern-title {
    color: var(--goa-color-interactive-default, #0070c4);
  }

  .pattern-desc {
    font: var(--goa-typography-body-s);
    color: var(--goa-color-text-secondary, #666);
  }

  @media (max-width: 900px) {
    .patterns-row {
      grid-template-columns: 1fr;
    }
  }
</style>
