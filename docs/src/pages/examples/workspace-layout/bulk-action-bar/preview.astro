---
/**
 * Workspace Layout: Bulk action bar live preview.
 * Embeds the standalone full-viewport render via iframe so the workspace
 * layout fills its own viewport at the default 100vh without needing a
 * height-prop override.
 */
import PreviewLayout from "../../../../layouts/PreviewLayout.astro";
import { withBase } from "@/lib/base-url";

const sourceFolder = "https://github.com/GovAlta/ui-components/tree/dev/docs/src/content/examples/workspace-layout/bulk-action-bar";
const reactSource = "https://github.com/GovAlta/ui-components/blob/dev/docs/src/content/examples/workspace-layout/bulk-action-bar/react.tsx";
const standaloneUrl = withBase("/examples/workspace-layout/bulk-action-bar/standalone");
---

<PreviewLayout
  title="Workspace bulk action bar preview"
  backUrl="/examples/workspace-layout"
  backLabel="Back to Workspace Layout"
  reactSourceUrl={reactSource}
  angularSourceUrl={sourceFolder}
>
  <iframe
    src={standaloneUrl}
    class="iframe-fill"
    title="Workspace layout bulk action bar live preview"
  ></iframe>
</PreviewLayout>

<style is:global>
  .iframe-fill {
    flex: 1;
    width: 100%;
    border: 0;
    display: block;
    background: #ffffff;
  }
</style>
