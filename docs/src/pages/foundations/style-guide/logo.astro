---
import { withBase } from '@/lib/base-url';
/**
 * Foundations - Style guide - Logo
 *
 * Logo guidance for Government of Alberta digital products.
 * Content adapted from Confluence export:
 * Foundations -> Style guide -> Logo.
 */
import DocumentationPageLayout from '../../../layouts/DocumentationPageLayout.astro';
import FoundationsSupportCallout from '../../../components/FoundationsSupportCallout.astro';
---

<DocumentationPageLayout
  title="Logo"
  description="Logo guidance and usage rules for Government of Alberta digital products"
  section="foundations"
>
  <goa-text size="heading-xl" mt="none" mb="m">Logo</goa-text>
  <goa-text size="body-l" mt="none" mb="2xl">
    The Alberta logo represents the Government of Alberta brand. Use the logo consistently to
    ensure digital products are clearly identifiable and aligned with government standards. Follow
    these guidelines when using the Alberta logo.
  </goa-text>

  <goa-divider version="2" mt="xl" mb="xl"></goa-divider>

  <h2 id="anatomy">Anatomy</h2>
  <goa-text size="body-m" mt="none" mb="m">
    The Alberta logo includes two elements:
  </goa-text>
  <goa-text size="body-m" mt="none" mb="m">
    <ul>
      <li><strong>Wordmark</strong></li>
      <li><strong>Symbol</strong></li>
    </ul>
  </goa-text>
  <goa-text size="body-m" mt="none" mb="xl">
    These elements work together to represent the Alberta brand.
  </goa-text>
  <img
    src={withBase(`/images/foundations/style-guide/logo-anatomy.svg`)}
    alt="Diagram showing Alberta logo anatomy, including the wordmark and symbol."
    width="354"
    height="352"
  />

  <goa-divider version="2" mt="xl" mb="xl"></goa-divider>

  <h2 id="primary-usage">Primary usage</h2>
  <goa-text size="body-m" mt="none" mb="xl">
    Use the primary Alberta logo for all digital products. The default version uses the
    <strong> stone grey </strong>
    wordmark and
    <strong> sky blue </strong>
    symbol. Display the logo prominently within the interface, typically in the header and footer.
    Design System components already include the Alberta logo where appropriate.
  </goa-text>
  <img
    src={withBase(`/images/foundations/style-guide/primary-usage-logo.svg`)}
    alt="Primary Alberta logo with stone grey wordmark and sky blue symbol."
    width="500"
    height="120"
  />

  <goa-divider version="2" mt="xl" mb="xl"></goa-divider>

  <h2 id="alternate-usage">Alternate usage</h2>
  <goa-text size="body-m" mt="none" mb="m">
    Use alternate logo versions only when the primary version cannot be applied.
  </goa-text>

  <h3 id="reverse-version-dark">Reverse version (dark)</h3>
  <goa-text size="body-m" mt="none" mb="m">
    Use the reversed wordmark on dark backgrounds. The wordmark retains the blue (sky) colour of
    the symbol.
  </goa-text>
  <img
    src={withBase(`/images/foundations/style-guide/reverse-version-logo.svg`)}
    alt="Reverse version of the Alberta logo for dark backgrounds."
    width="500"
    height="119"
  />

  <h3 id="white-version">White version</h3>
  <goa-text size="body-m" mt="none" mb="m">
    Use the white version when a simplified logo is required. The background must be one of the
    official Alberta brand colours.
  </goa-text>
  <img
    src={withBase(`/images/foundations/style-guide/white-version-logo.svg`)}
    alt="White version of the Alberta logo."
    width="500"
    height="119"
  />

  <h3 id="black-version">Black version</h3>
  <goa-text size="body-m" mt="none" mb="xl">
    Use the black version when colour is not available.
  </goa-text>
  <img
    src={withBase(`/images/foundations/style-guide/black-version-logo.svg`)}
    alt="Black version of the Alberta logo."
    width="500"
    height="119"
  />

  <goa-divider version="2" mt="xl" mb="xl"></goa-divider>

  <h2 id="alberta-service-logo">Alberta service logo</h2>
  <goa-text size="body-m" mt="none" mb="xl">
    When the Alberta logo appears with a service name, maintain protective space around the logo
    and service name.
    The required spacing is equal to the height and width of the period symbol shown in the logo.
    Do not place text or visual elements within this protected space.
  </goa-text>
  <img
    src={withBase(`/images/foundations/style-guide/alberta-service-logo.svg`)}
    alt="Alberta service logo with required protective spacing."
    width="394"
    height="126"
  />

  <goa-divider version="2" mt="xl" mb="xl"></goa-divider>

  <h2 id="alberta-sub-mark">Alberta sub-mark</h2>
  <goa-text size="body-m" mt="none" mb="m">
    Use the Alberta sub-mark when space is limited.
  </goa-text>
  <img
    src={withBase(`/images/foundations/style-guide/alberta-sub-mark.svg`)}
    alt="Alberta sub-mark."
    width="139"
    height="139"
  />
  <goa-text size="body-m" mt="none" mb="m">Common uses include:</goa-text>
  <goa-text size="body-m" mt="none" mb="m">
    <ul>
      <li>Mobile interfaces</li>
      <li>Favicons</li>
      <li>Browser tab icons</li>
    </ul>
  </goa-text>
  <goa-text size="body-m" mt="none" mb="xl">
    This ensures the product remains identifiable when the full logo cannot be displayed.
  </goa-text>

  <goa-divider version="2" mt="xl" mb="xl"></goa-divider>

  <h2 id="logo-usage-guidelines">Logo usage guidelines</h2>
  <goa-text size="body-m" mt="none" mb="m">
    <ul>
      <li>Do not modify the logo</li>
      <li>Use only official logo files from the asset library</li>
      <li>Do not change the spacing between the wordmark and symbol</li>
      <li>Maintain the required protective space around the logo</li>
      <li>Use alternate logo versions only in their intended contexts</li>
      <li>
        Use the official logo components available in the
        <goa-link trailingicon="open">
          <a href="https://www.figma.com/design/Jpy1Ea5qglwnp1SgGnagY9/%E2%9D%96-BETA-Component-library?node-id=58757-186832&t=5yWrqT4OmMNL35oY-4" target="_blank" rel="noopener noreferrer">
            Header
          </a>
        </goa-link>
        and the
        <goa-link trailingicon="open">
          <a href="https://www.figma.com/design/Jpy1Ea5qglwnp1SgGnagY9/%E2%9D%96-BETA-Component-library?node-id=57622-159377&t=5yWrqT4OmMNL35oY-4" target="_blank" rel="noopener noreferrer">
            Work side menu
          </a>
        </goa-link>
        to ensure accuracy and consistency.
      </li>
      <li>
        Use the full
        <strong> Alberta logo </strong>
        in application headers on desktop screens. For smaller screen sizes, such as mobile, use
        the
        <strong> Alberta sub-mark </strong>.
        Refer to the
        <goa-link trailingicon="open">
          <a href="https://www.figma.com/design/Jpy1Ea5qglwnp1SgGnagY9/%E2%9D%96-BETA-Component-library?node-id=60130-202144&t=5JwqXKdq60q8KpUE-1" target="_blank" rel="noopener noreferrer">
            Figma asset library
          </a>
        </goa-link>
        for guidance.
      </li>
    </ul>
  </goa-text>
  <goa-text size="body-m" mt="none" mb="xl">
    The Alberta logo cannot be used for commercial purposes without permission. Refer to the
    <goa-link trailingicon="open">
      <a href="https://open.alberta.ca/publications/government-identity-policy" target="_blank" rel="noopener noreferrer">
        Government Identity Policy
      </a>
    </goa-link>
    for additional guidance.
  </goa-text>

  <FoundationsSupportCallout />
</DocumentationPageLayout>
